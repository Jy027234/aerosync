# ==========================================
# AeroSync Cloud - 环境变量配置示例
# 复制为 .env 后填入真实密钥
# ==========================================

# --- 存储配置 ---
# 支持: oss (阿里云) | minio (私有化)
STORAGE_TYPE=oss

# --- 对象存储 (阿里云 OSS) ---
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET=aerosync-dev

# --- 对象存储 (MinIO - 私有化内网部署) ---
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=aerosync
# MINIO_SECURE=false

# --- 大语言模型 通用配置 (向后兼容) ---
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 多 Provider LLM 选择 ---
# 支持: openai | deepseek | claude | ollama
LLM_PROVIDER=openai

# Claude (Anthropic) 独立配置
# CLAUDE_API_KEY=your-anthropic-key
# CLAUDE_BASE_URL=https://api.anthropic.com/v1
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# DeepSeek 独立配置
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# Ollama 本地部署配置
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:14b

# --- Webhook 默认推送地址（可选）---
DEFAULT_WEBHOOK_URL=
DEFAULT_WEBHOOK_SECRET=

# --- 混合解析引擎（Phase 2）---
# 启用后 PDF/Word 将自动路由到 Docling 进行复杂版面解析
ENABLE_HYBRID_PARSER=false

# --- API 安全 ---
API_TOKEN=change-me-in-production

# --- 数据库 & Redis (docker-compose 中已默认配置，按需覆盖) ---
# DATABASE_URL=postgresql://aerosync:aerosync@postgres:5432/aerosync
# REDIS_URL=redis://redis:6379/0
