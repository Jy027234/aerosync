FROM python:3.11

WORKDIR /app

# 使用腾讯云镜像安装Python依赖
COPY api/requirements.txt .
RUN pip install --no-cache-dir -i https://mirrors.cloud.tencent.com/pypi/simple -r requirements.txt

# 复制应用代码
COPY api/ ./api/
COPY worker/ ./worker/

ENV PYTHONPATH=/app

EXPOSE 8080

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8080"]
